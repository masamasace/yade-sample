diff --git a/pkg/dem/CohesiveFrictionalContactLaw.cpp b/pkg/dem/CohesiveFrictionalContactLaw.cpp
index c149e48..b842e66 100644
--- a/pkg/dem/CohesiveFrictionalContactLaw.cpp
+++ b/pkg/dem/CohesiveFrictionalContactLaw.cpp
@@ -366,6 +366,21 @@ bool Law2_ScGeom6D_CohFrictPhys_CohesionMoment::go(shared_ptr<IGeom>& ig, shared
 		scene->forces.addTorque(id1, -moment);
 		scene->forces.addTorque(id2, moment);
 	}
+	// Track elastic potential energy (per component and total)
+	if (scene->trackEnergy) {
+		Real eNorm = (phys->kn > 0) ? 0.5 * (phys->normalForce.squaredNorm() / phys->kn) : 0;
+		Real eShear = (phys->ks > 0) ? 0.5 * (phys->shearForce.squaredNorm() / phys->ks) : 0;
+		Real eBending = 0, eTwist = 0;
+		if (computeMoment) {
+			eBending = (phys->kr > 0) ? 0.5 * (phys->moment_bending.squaredNorm() / phys->kr) : 0;
+			eTwist = (phys->ktw > 0) ? 0.5 * (phys->moment_twist.squaredNorm() / phys->ktw) : 0;
+		}
+		scene->energy->add(eNorm, "elastPotentialNorm", elastPotentialNormIx, /*reset*/ true);
+		scene->energy->add(eShear, "elastPotentialShear", elastPotentialShearIx, /*reset*/ true);
+		scene->energy->add(eBending, "elastPotentialBending", elastPotentialBendingIx, /*reset*/ true);
+		scene->energy->add(eTwist, "elastPotentialTwist", elastPotentialTwistIx, /*reset*/ true);
+		scene->energy->add(eNorm + eShear + eBending + eTwist, "elastPotential", elastPotentialIx, /*reset*/ true);
+	}
 	return true;
 }
 
